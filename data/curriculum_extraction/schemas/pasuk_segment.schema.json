{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Pasuk Segment",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "id",
    "schema_version",
    "record_type",
    "extraction_batch_id",
    "source_package_id",
    "source_trace",
    "review_status",
    "runtime_status",
    "confidence",
    "extraction_quality_flags",
    "canonical_ref",
    "sefer",
    "parsha",
    "perek",
    "pasuk",
    "pasuk_range",
    "segment_order",
    "segment_level",
    "hebrew_raw",
    "hebrew_normalized",
    "english_raw",
    "english_normalized",
    "missing_hebrew_flag",
    "missing_translation_flag",
    "translation_type",
    "parenthetical_clarification",
    "translation_rule_tags",
    "source_footnote_refs",
    "skill_tags",
    "linked_vocab_ids",
    "linked_word_parse_ids"
  ],
  "properties": {
    "id": { "type": "string" },
    "schema_version": { "type": "string" },
    "record_type": { "type": "string", "const": "pasuk_segment" },
    "extraction_batch_id": { "type": "string" },
    "source_package_id": { "type": "string" },
    "source_trace": { "type": "object" },
    "review_status": { "type": "string" },
    "runtime_status": { "type": "string" },
    "confidence": { "type": "string" },
    "extraction_quality_flags": { "type": "array", "items": { "type": "string" } },
    "canonical_ref": { "type": "string" },
    "sefer": { "type": "string" },
    "parsha": { "type": "string" },
    "perek": { "type": "integer" },
    "pasuk": { "type": "integer" },
    "pasuk_range": { "type": "string" },
    "segment_order": { "type": "integer" },
    "segment_level": { "type": "string" },
    "hebrew_raw": { "type": "string" },
    "hebrew_normalized": { "type": "string" },
    "english_raw": { "type": "string" },
    "english_normalized": { "type": "string" },
    "missing_hebrew_flag": { "type": "boolean" },
    "missing_translation_flag": { "type": "boolean" },
    "translation_type": { "type": "string" },
    "parenthetical_clarification": { "type": "string" },
    "translation_rule_tags": { "type": "array", "items": { "type": "string" } },
    "source_footnote_refs": { "type": "array", "items": { "type": "string" } },
    "skill_tags": { "type": "array", "items": { "type": "string" } },
    "linked_vocab_ids": { "type": "array", "items": { "type": "string" } },
    "linked_word_parse_ids": { "type": "array", "items": { "type": "string" } }
  }
}
