{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Question Template",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "id",
    "schema_version",
    "record_type",
    "extraction_batch_id",
    "source_package_id",
    "source_trace",
    "review_status",
    "runtime_status",
    "confidence",
    "extraction_quality_flags",
    "template_key",
    "template_title",
    "question_family",
    "prompt_template",
    "expected_answer_type",
    "supported_record_types",
    "skill_tags"
  ],
  "properties": {
    "id": { "type": "string" },
    "schema_version": { "type": "string" },
    "record_type": { "type": "string", "const": "question_template" },
    "extraction_batch_id": { "type": "string" },
    "source_package_id": { "type": "string" },
    "source_trace": { "type": "object" },
    "review_status": { "type": "string" },
    "runtime_status": { "type": "string" },
    "confidence": { "type": "string" },
    "extraction_quality_flags": { "type": "array", "items": { "type": "string" } },
    "template_key": { "type": "string" },
    "template_title": { "type": "string" },
    "question_family": { "type": "string" },
    "prompt_template": { "type": "string" },
    "expected_answer_type": { "type": "string" },
    "supported_record_types": { "type": "array", "items": { "type": "string" } },
    "skill_tags": { "type": "array", "items": { "type": "string" } }
  }
}
