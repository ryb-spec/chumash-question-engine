{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Translation Rule",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "id",
    "schema_version",
    "record_type",
    "extraction_batch_id",
    "source_package_id",
    "source_trace",
    "review_status",
    "runtime_status",
    "confidence",
    "extraction_quality_flags",
    "rule_key",
    "rule_name",
    "applies_to_record_type",
    "trigger_text",
    "guidance",
    "example_source_ref",
    "skill_tags"
  ],
  "properties": {
    "id": { "type": "string" },
    "schema_version": { "type": "string" },
    "record_type": { "type": "string", "const": "translation_rule" },
    "extraction_batch_id": { "type": "string" },
    "source_package_id": { "type": "string" },
    "source_trace": { "type": "object" },
    "review_status": { "type": "string" },
    "runtime_status": { "type": "string" },
    "confidence": { "type": "string" },
    "extraction_quality_flags": { "type": "array", "items": { "type": "string" } },
    "rule_key": { "type": "string" },
    "rule_name": { "type": "string" },
    "applies_to_record_type": { "type": "string" },
    "trigger_text": { "type": "string" },
    "guidance": { "type": "string" },
    "example_source_ref": { "type": "string" },
    "skill_tags": { "type": "array", "items": { "type": "string" } }
  }
}
