{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Vocabulary Entry",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "id",
    "schema_version",
    "record_type",
    "extraction_batch_id",
    "source_package_id",
    "source_trace",
    "review_status",
    "runtime_status",
    "confidence",
    "extraction_quality_flags",
    "hebrew",
    "normalized_hebrew",
    "entry_type",
    "english_glosses",
    "needs_gloss_review",
    "sefer_scope",
    "frequency_source",
    "frequency_band",
    "global_frequency_band",
    "priority_level",
    "skill_tags"
  ],
  "properties": {
    "id": { "type": "string" },
    "schema_version": { "type": "string" },
    "record_type": { "type": "string", "const": "vocab_entry" },
    "extraction_batch_id": { "type": "string" },
    "source_package_id": { "type": "string" },
    "source_trace": { "type": "object" },
    "review_status": { "type": "string" },
    "runtime_status": { "type": "string" },
    "confidence": { "type": "string" },
    "extraction_quality_flags": { "type": "array", "items": { "type": "string" } },
    "hebrew": { "type": "string" },
    "normalized_hebrew": { "type": "string" },
    "entry_type": { "type": "string" },
    "english_glosses": { "type": "array", "items": { "type": "string" } },
    "needs_gloss_review": { "type": "boolean" },
    "sefer_scope": { "type": "array", "items": { "type": "string" } },
    "frequency_source": { "type": "string" },
    "frequency_band": { "type": "string" },
    "global_frequency_band": { "type": "string" },
    "priority_level": { "type": "string" },
    "skill_tags": { "type": "array", "items": { "type": "string" } }
  }
}
