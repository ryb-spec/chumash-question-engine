{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Word Parse Task",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "id",
    "schema_version",
    "record_type",
    "extraction_batch_id",
    "source_package_id",
    "source_trace",
    "review_status",
    "runtime_status",
    "confidence",
    "extraction_quality_flags",
    "task_type",
    "sefer",
    "parsha",
    "perek",
    "pasuk",
    "pasuk_range",
    "target_shoresh_raw",
    "target_shoresh_normalized",
    "expected_word_in_pasuk",
    "prefixes",
    "suffixes",
    "answer_status",
    "skill_tags"
  ],
  "properties": {
    "id": { "type": "string" },
    "schema_version": { "type": "string" },
    "record_type": { "type": "string", "const": "word_parse_task" },
    "extraction_batch_id": { "type": "string" },
    "source_package_id": { "type": "string" },
    "source_trace": { "type": "object" },
    "review_status": { "type": "string" },
    "runtime_status": { "type": "string" },
    "confidence": { "type": "string" },
    "extraction_quality_flags": { "type": "array", "items": { "type": "string" } },
    "task_type": { "type": "string" },
    "sefer": { "type": "string" },
    "parsha": { "type": "string" },
    "perek": { "type": "integer" },
    "pasuk": { "type": "integer" },
    "pasuk_range": { "type": "string" },
    "target_shoresh_raw": { "type": "string" },
    "target_shoresh_normalized": { "type": "string" },
    "expected_word_in_pasuk": { "type": "string" },
    "prefixes": { "type": "array", "items": { "type": "object" } },
    "suffixes": { "type": "array", "items": { "type": "object" } },
    "answer_status": {
      "type": "string",
      "enum": [
        "source_provided",
        "inferred_needs_review",
        "not_provided",
        "not_extracted",
        "not_applicable"
      ]
    },
    "skill_tags": { "type": "array", "items": { "type": "string" } }
  }
}
