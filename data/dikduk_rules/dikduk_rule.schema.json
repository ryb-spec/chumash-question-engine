{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dikduk_rule.schema.json",
  "title": "Dikduk Rule",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "rule_id",
    "schema_version",
    "rule_group",
    "skill_name",
    "status",
    "source_reference",
    "student_facing_rule",
    "technical_rule",
    "examples",
    "common_errors",
    "question_template_ids",
    "feedback_templates",
    "mastery_tags",
    "difficulty_level",
    "prerequisite_rule_ids",
    "followup_rule_ids",
    "zekelman_alignment"
  ],
  "properties": {
    "rule_id": {
      "type": "string",
      "pattern": "^DK-[A-Z]+(?:-[A-Z]+)*-\\d{3}$"
    },
    "schema_version": {
      "type": "string"
    },
    "rule_group": {
      "type": "string"
    },
    "skill_name": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "source_reference": {
      "type": "object",
      "additionalProperties": true,
      "required": ["source_file", "lesson", "source_note"],
      "properties": {
        "source_file": { "type": "string" },
        "lesson": { "type": "integer", "minimum": 1 },
        "page_observed": { "type": ["integer", "null"] },
        "source_note": { "type": "string" }
      }
    },
    "student_facing_rule": {
      "type": "string"
    },
    "technical_rule": {
      "type": "object",
      "additionalProperties": true
    },
    "examples": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["hebrew", "analysis", "translation"],
        "additionalProperties": true
      }
    },
    "counterexamples": {
      "type": "array"
    },
    "exceptions_or_warnings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "common_errors": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "question_template_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^QT-DK-[A-Z]+(?:-[A-Z]+)*-\\d{3}-[A-Z]$"
      }
    },
    "feedback_templates": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "type": "string" }
    },
    "mastery_tags": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "difficulty_level": {
      "type": "integer",
      "minimum": 1
    },
    "prerequisite_rule_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^DK-[A-Z]+(?:-[A-Z]+)*-\\d{3}$"
      }
    },
    "followup_rule_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^DK-[A-Z]+(?:-[A-Z]+)*-\\d{3}$"
      }
    },
    "zekelman_alignment": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    }
  }
}
