{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dikduk_question_template.schema.json",
  "title": "Dikduk Question Template",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "template_id",
    "schema_version",
    "rule_id",
    "question_type",
    "prompt_template",
    "answer_template",
    "distractor_strategy",
    "feedback_correct",
    "feedback_incorrect",
    "mastery_tags",
    "status"
  ],
  "properties": {
    "template_id": {
      "type": "string",
      "pattern": "^QT-DK-[A-Z]+(?:-[A-Z]+)*-\\d{3}-[A-Z]$"
    },
    "schema_version": {
      "type": "string"
    },
    "rule_id": {
      "type": "string",
      "pattern": "^DK-[A-Z]+(?:-[A-Z]+)*-\\d{3}$"
    },
    "question_type": {
      "type": "string"
    },
    "prompt_template": {
      "type": "string"
    },
    "answer_template": {
      "type": "string"
    },
    "distractor_strategy": {
      "type": "array",
      "items": { "type": "string" }
    },
    "feedback_correct": {
      "type": "string"
    },
    "feedback_incorrect": {
      "type": "string"
    },
    "mastery_tags": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "status": {
      "type": "string"
    }
  }
}
